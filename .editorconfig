# EditorConfig - Ensures consistent coding styles across editors and IDEs
# https://editorconfig.org

root = true

# All files - defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON, TOML
[*.{json,toml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Windows-specific files
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Makefile
[Makefile]
indent_style = tab
