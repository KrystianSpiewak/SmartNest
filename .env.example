# SmartNest Environment Configuration
# Copy to .env and modify for your environment.
# All variables prefixed with SMARTNEST_ are read by pydantic-settings.

# -- Logging -------------------------------------------------------------------
SMARTNEST_LOG_LEVEL=DEBUG
SMARTNEST_LOG_RENDERER=console

# -- MQTT Broker ---------------------------------------------------------------
SMARTNEST_MQTT_BROKER=localhost
SMARTNEST_MQTT_PORT=1883
SMARTNEST_MQTT_CLIENT_ID=smartnest_main
# SMARTNEST_MQTT_USERNAME=
# SMARTNEST_MQTT_PASSWORD=
SMARTNEST_MQTT_KEEPALIVE=60
SMARTNEST_MQTT_TLS_ENABLED=false
SMARTNEST_MQTT_RECONNECT_MIN_DELAY=1
SMARTNEST_MQTT_RECONNECT_MAX_DELAY=60

# -- Database ------------------------------------------------------------------
SMARTNEST_DATABASE_URL=smartnest.db

# -- Security ------------------------------------------------------------------
SMARTNEST_JWT_SECRET=change-me-in-production
SMARTNEST_JWT_ALGORITHM=HS256
SMARTNEST_JWT_EXPIRE_MINUTES=15
SMARTNEST_BCRYPT_ROUNDS=12

# -- Server --------------------------------------------------------------------
SMARTNEST_HOST=127.0.0.1
SMARTNEST_PORT=8000
